"use client"

import Link from "next/link"
import { Sparkles, Briefcase, FileEdit, Bot } from "lucide-react"

interface SidebarNavProps {
  activeSection: string
  onSectionChange: (section: string) => void
}

const items = [
  {
    id: "showcase",
    label: "Live Showcase",
    icon: Sparkles,
  },
  {
    id: "projects",
    label: "Client Projects",
    icon: Briefcase,
  },
  {
    id: "custom",
    label: "Custom Orders",
    icon: FileEdit,
  },
]

export function SidebarNav({ activeSection, onSectionChange }: SidebarNavProps) {
  return (
    <nav className="group/nav fixed right-4 top-1/2 z-50 flex -translate-y-1/2 flex-col gap-3">
      {items.map((item) => {
        const Icon = item.icon
        const active = activeSection === item.id

        return (
          <button
            key={item.id}
            type="button"
            onClick={() => onSectionChange(item.id)}
            className={[
              "relative flex h-14 w-14 items-center overflow-hidden rounded-2xl border transition-all duration-300 ease-out",
              "group-hover/nav:w-48",
              active
                ? "border-primary bg-primary/20 shadow-[0_0_20px_rgba(255,0,0,0.30)]"
                : "border-border/50 bg-card/80 backdrop-blur-sm hover:border-primary/50 hover:bg-card hover:shadow-[0_0_16px_rgba(255,0,0,0.18)]",
            ].join(" ")}
            aria-label={item.label}
            title={item.label}
          >
            <div className="flex h-14 w-14 shrink-0 items-center justify-center">
              <Icon
                className={[
                  "h-5 w-5 transition-all duration-300",
                  active ? "text-primary" : "text-primary/90",
                ].join(" ")}
              />
            </div>

            <span
              className={[
                "whitespace-nowrap pr-4 text-sm font-medium transition-all duration-300",
                "opacity-0 translate-x-2 group-hover/nav:translate-x-0 group-hover/nav:opacity-100",
                active ? "text-white" : "text-foreground/90",
              ].join(" ")}
            >
              {item.label}
            </span>

            {active && (
              <div className="absolute left-0 top-3 h-8 w-1 rounded-r-full bg-primary shadow-[0_0_12px_rgba(255,0,0,0.8)]" />
            )}
          </button>
        )
      })}

      <Link
        href="/bots"
        className="relative flex h-14 w-14 items-center overflow-hidden rounded-2xl border border-border/50 bg-card/80 backdrop-blur-sm transition-all duration-300 ease-out hover:border-primary/50 hover:bg-card hover:shadow-[0_0_16px_rgba(255,0,0,0.18)] group-hover/nav:w-48"
        aria-label="Discord Bots"
        title="Discord Bots"
      >
        <div className="flex h-14 w-14 shrink-0 items-center justify-center">
          <Bot className="h-5 w-5 text-primary/90 transition-all duration-300" />
        </div>

        <span className="whitespace-nowrap pr-4 text-sm font-medium text-foreground/90 opacity-0 translate-x-2 transition-all duration-300 group-hover/nav:translate-x-0 group-hover/nav:opacity-100">
          Discord Bots
        </span>
      </Link>
    </nav>
  )
}
